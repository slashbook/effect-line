{
  "extends": "../../tsconfig.base.json",
  "include": ["src", "test"],
  "exclude": ["test/**/*"],
  "references": [
    { "path": "../config" }
  ],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["node"],
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@line/bot-sdk": ["./node_modules/@line/bot-sdk"],
      "@effect-line/config": ["../config/src"]
    }
  }
}
