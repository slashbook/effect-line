{
  "name": "@effect-line/messaging-api",
  "version": "0.0.1",
  "type": "module",
  "description": "Effect-based LINE Messaging API client",
  "author": "Chen Hsin-Yi",
  "license": "MIT",
  "keywords": [
    "effect",
    "line",
    "bot",
    "sdk",
    "messaging",
    "api"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/effect-line.git"
  },
  "bugs": {
